<UserControl x:Class="MVXTester.App.Views.EditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:nodify="https://miroiu.github.io/nodify"
             xmlns:vm="clr-namespace:MVXTester.App.ViewModels"
             xmlns:conv="clr-namespace:MVXTester.App.Converters"
             xmlns:models="clr-namespace:MVXTester.Core.Models;assembly=MVXTester.Core">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:NullToVisibilityConverter x:Key="NullToVis" />
        <conv:StringNotEmptyToVisibilityConverter x:Key="StringNotEmptyToVis" />

        <DataTemplate DataType="{x:Type vm:ConnectorViewModel}">
            <nodify:NodeInput Header="{Binding DisplayName}"
                              Anchor="{Binding Anchor, Mode=OneWayToSource}"
                              IsConnected="{Binding IsConnected}"
                              BorderBrush="{DynamicResource AccentBrush}" />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:ConnectionViewModel}">
            <nodify:LineConnection Source="{Binding Source.Anchor}"
                                   Target="{Binding Target.Anchor}"
                                   Stroke="{DynamicResource AccentBrush}"
                                   StrokeThickness="2" />
        </DataTemplate>
    </UserControl.Resources>

    <nodify:NodifyEditor x:Name="Editor"
                         ItemsSource="{Binding Nodes}"
                         Connections="{Binding Connections}"
                         PendingConnection="{Binding PendingConnection}"
                         SelectedItems="{Binding SelectedNodes}"
                         ItemsDragStartedCommand="{Binding ItemsDragStartedCommand}"
                         ItemsDragCompletedCommand="{Binding ItemsDragCompletedCommand}"
                         Background="{DynamicResource BackgroundBrush}"
                         GridCellSize="20"
                         DisableAutoPanning="False"
                         AllowDrop="True"
                         Drop="Editor_Drop"
                         DragOver="Editor_DragOver"
                         PreviewDragOver="Editor_DragOver">

        <nodify:NodifyEditor.PendingConnectionTemplate>
            <DataTemplate DataType="{x:Type vm:PendingConnectionViewModel}">
                <nodify:PendingConnection StartedCommand="{Binding StartCommand}"
                                          CompletedCommand="{Binding FinishCommand}"
                                          Stroke="{DynamicResource WarningBrush}"
                                          StrokeThickness="2"
                                          StrokeDashArray="4 2"
                                          Visibility="{Binding IsVisible, Converter={StaticResource BoolToVis}}" />
            </DataTemplate>
        </nodify:NodifyEditor.PendingConnectionTemplate>

        <nodify:NodifyEditor.ItemTemplate>
            <DataTemplate DataType="{x:Type vm:NodeViewModel}">
                <Grid>
                    <nodify:Node Header="{Binding Title}"
                                 Input="{Binding InputConnectors}"
                                 Output="{Binding OutputConnectors}"
                                 HeaderBrush="{Binding CategoryColor}"
                                 ContentBrush="{DynamicResource SurfaceBrush}"
                                 FooterBrush="{DynamicResource SurfaceBrush}"
                                 Foreground="{DynamicResource ForegroundBrush}"
                                 Background="{DynamicResource SurfaceBrush}">
                        <nodify:Node.Style>
                            <Style TargetType="nodify:Node" BasedOn="{StaticResource {x:Type nodify:Node}}">
                                <Setter Property="BorderBrush" Value="{Binding CategoryBorderColor}" />
                                <Setter Property="BorderThickness" Value="1.5" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ExecutionState}" Value="{x:Static models:NodeExecutionState.Executing}">
                                        <Setter Property="BorderBrush" Value="{DynamicResource WarningBrush}" />
                                        <Setter Property="BorderThickness" Value="2.5" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ExecutionState}" Value="{x:Static models:NodeExecutionState.Success}">
                                        <Setter Property="BorderBrush" Value="{DynamicResource SuccessBrush}" />
                                        <Setter Property="BorderThickness" Value="2" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ExecutionState}" Value="{x:Static models:NodeExecutionState.Error}">
                                        <Setter Property="BorderBrush" Value="{DynamicResource ErrorBrush}" />
                                        <Setter Property="BorderThickness" Value="2.5" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </nodify:Node.Style>
                        <nodify:Node.Footer>
                            <StackPanel>
                                <Image Source="{Binding PreviewImage}"
                                       MaxWidth="160" MaxHeight="120"
                                       Stretch="Uniform" Margin="4"
                                       Visibility="{Binding PreviewImage, Converter={StaticResource NullToVis}}" />
                                <!-- Text-based preview (Print node etc.) -->
                                <Border Background="{DynamicResource SurfaceHoverBrush}" CornerRadius="3" Padding="6,4" Margin="4,2,4,4"
                                        MaxWidth="240" MaxHeight="200"
                                        Visibility="{Binding PreviewText, Converter={StaticResource StringNotEmptyToVis}}">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                                  MaxHeight="192">
                                        <TextBlock Text="{Binding PreviewText}" FontSize="10.5"
                                                   FontFamily="Consolas, Courier New, monospace"
                                                   Foreground="{DynamicResource ForegroundBrush}"
                                                   TextWrapping="Wrap" />
                                    </ScrollViewer>
                                </Border>
                                <Border Background="{DynamicResource ErrorHintBrush}" CornerRadius="2" Padding="4,2" Margin="4,0,4,4"
                                        Visibility="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyToVis}}">
                                    <TextBlock Text="{Binding ErrorMessage}" FontSize="10"
                                               Foreground="{DynamicResource ErrorBrush}"
                                               TextWrapping="Wrap" MaxWidth="160" />
                                </Border>
                            </StackPanel>
                        </nodify:Node.Footer>

                        <nodify:Node.InputConnectorTemplate>
                            <DataTemplate DataType="{x:Type vm:ConnectorViewModel}">
                                <nodify:NodeInput Header="{Binding DisplayName}"
                                                  Anchor="{Binding Anchor, Mode=OneWayToSource}"
                                                  IsConnected="{Binding IsConnected}"
                                                  Background="{DynamicResource SurfaceBrush}"
                                                  Foreground="{DynamicResource ForegroundDimBrush}"
                                                  FontSize="10"
                                                  BorderBrush="{Binding TypeColor}"
                                                  MouseDoubleClick="Connector_MouseDoubleClick" />
                            </DataTemplate>
                        </nodify:Node.InputConnectorTemplate>

                        <nodify:Node.OutputConnectorTemplate>
                            <DataTemplate DataType="{x:Type vm:ConnectorViewModel}">
                                <nodify:NodeOutput Header="{Binding DisplayName}"
                                                   Anchor="{Binding Anchor, Mode=OneWayToSource}"
                                                   IsConnected="{Binding IsConnected}"
                                                   Background="{DynamicResource SurfaceBrush}"
                                                   Foreground="{DynamicResource ForegroundDimBrush}"
                                                   FontSize="10"
                                                   BorderBrush="{Binding TypeColor}"
                                                   MouseDoubleClick="Connector_MouseDoubleClick" />
                            </DataTemplate>
                        </nodify:Node.OutputConnectorTemplate>
                    </nodify:Node>

                    <!-- Delete button at top-right corner -->
                    <Button Width="18" Height="18"
                            HorizontalAlignment="Right" VerticalAlignment="Top"
                            Margin="0,-2,-2,0"
                            Cursor="Hand"
                            Command="{Binding DataContext.DeleteNodeCommand, RelativeSource={RelativeSource AncestorType={x:Type nodify:NodifyEditor}}}"
                            CommandParameter="{Binding}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" Background="{DynamicResource ErrorSemiBrush}" CornerRadius="9"
                                                    Width="18" Height="18" Opacity="0">
                                                <TextBlock Text="✕" FontSize="10" FontWeight="Bold"
                                                           Foreground="White"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           Margin="0,-1,0,0" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter TargetName="Bd" Property="Opacity" Value="0.7" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Grid}}" Value="True">
                                                    <Setter TargetName="Bd" Property="Opacity" Value="0.7" />
                                                </DataTrigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Opacity" Value="1" />
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ErrorBrush}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </DataTemplate>
        </nodify:NodifyEditor.ItemTemplate>

        <nodify:NodifyEditor.ItemContainerStyle>
            <Style TargetType="{x:Type nodify:ItemContainer}">
                <Setter Property="Location" Value="{Binding Location}" />
                <Setter Property="IsSelected" Value="{Binding IsSelected}" />
            </Style>
        </nodify:NodifyEditor.ItemContainerStyle>

        <nodify:NodifyEditor.ConnectionTemplate>
            <DataTemplate DataType="{x:Type vm:ConnectionViewModel}">
                <nodify:Connection Source="{Binding Source.Anchor}"
                                   Target="{Binding Target.Anchor}"
                                   Stroke="{Binding Source.TypeColor}"
                                   StrokeThickness="2"
                                   MouseRightButtonDown="Connection_MouseRightButtonDown" />
            </DataTemplate>
        </nodify:NodifyEditor.ConnectionTemplate>
    </nodify:NodifyEditor>
</UserControl>
