<UserControl x:Class="MVXTester.Chat.Views.ChatbotView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:MVXTester.Chat.Converters">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBoolConverter x:Key="InverseBool" />

        <!-- User message bubble style -->
        <DataTemplate x:Key="UserMessageTemplate">
            <Border Background="#2563EB" CornerRadius="12,12,2,12"
                    Padding="10,8" Margin="40,4,8,4"
                    HorizontalAlignment="Right">
                <StackPanel>
                    <Image Source="{Binding AttachedImage}" MaxHeight="120"
                           HorizontalAlignment="Right" Margin="0,0,0,6"
                           Visibility="{Binding HasAttachedImage, Converter={StaticResource BoolToVis}}" />
                    <TextBox Text="{Binding Content, Mode=OneWay}" TextWrapping="Wrap"
                             Foreground="White" FontSize="12"
                             IsReadOnly="True" BorderThickness="0" Padding="0"
                             Background="Transparent" Cursor="Arrow"
                             IsTabStop="False"
                             SelectionBrush="White" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- Assistant message bubble style -->
        <DataTemplate x:Key="AssistantMessageTemplate">
            <StackPanel HorizontalAlignment="Left">
                <Border Background="{DynamicResource HighlightBrush}" CornerRadius="12,12,12,2"
                        Padding="10,8" Margin="8,4,40,4">
                    <TextBox Text="{Binding Content, Mode=OneWay}" TextWrapping="Wrap"
                             Foreground="{DynamicResource ForegroundBrush}" FontSize="12"
                             IsReadOnly="True" BorderThickness="0" Padding="0"
                             Background="Transparent" Cursor="Arrow"
                             IsTabStop="False" />
                </Border>
                <!-- 예제 보기 버튼 (예제가 매핑된 경우만 표시) -->
                <Button Content="&#x1F4C2; 예제 열기"
                        Command="{Binding LoadExampleCommand}"
                        Visibility="{Binding HasExample, Converter={StaticResource BoolToVis}}"
                        HorizontalAlignment="Left" Margin="8,2,0,4"
                        Padding="8,4" FontSize="11"
                        ToolTip="{Binding ExampleFileName}" />
                <!-- 액션 링크 (URL 하이퍼링크) -->
                <TextBlock Margin="12,2,0,4" FontSize="11"
                           Visibility="{Binding HasActionUrl, Converter={StaticResource BoolToVis}}">
                    <Hyperlink NavigateUri="{Binding ActionUrl}"
                               RequestNavigate="OnHyperlinkNavigate"
                               Foreground="#5B9BD5">
                        <Run Text="{Binding ActionUrlText, Mode=OneWay}" />
                    </Hyperlink>
                </TextBlock>
                <!-- 도움말 열기 버튼 (오류/답변 불가 시 표시) -->
                <Button Content="&#x2753; 도움말 열기"
                        Command="{Binding OpenHelpCommand}"
                        Visibility="{Binding ShowHelpButton, Converter={StaticResource BoolToVis}}"
                        HorizontalAlignment="Left" Margin="8,2,0,4"
                        Padding="8,4" FontSize="11"
                        ToolTip="도움말 창 열기 (F1)" />
            </StackPanel>
        </DataTemplate>

        <!-- Message template selector -->
        <Style x:Key="MessageItemStyle" TargetType="ContentPresenter">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsUser}" Value="True">
                    <Setter Property="ContentTemplate" Value="{StaticResource UserMessageTemplate}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsUser}" Value="False">
                    <Setter Property="ContentTemplate" Value="{StaticResource AssistantMessageTemplate}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header: Settings + Model name -->
        <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="8,6">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="&#x2699;"
                        Command="{Binding OpenSettingsCommand}"
                        Width="26" Height="26" FontSize="14" Padding="0"
                        ToolTip="Chat Settings" VerticalAlignment="Center" />
                <Button DockPanel.Dock="Right" Content="&#x1F5D1;"
                        Command="{Binding ClearChatCommand}"
                        Width="26" Height="26" FontSize="11" Padding="0" Margin="0,0,4,0"
                        ToolTip="Clear Chat" VerticalAlignment="Center" />
                <TextBlock Text="{Binding CurrentModel}" FontSize="11"
                           Foreground="{DynamicResource ForegroundDimBrush}"
                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
            </DockPanel>
        </Border>

        <!-- Chat messages area -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      x:Name="MessageScrollViewer"
                      Padding="0,4">
            <ItemsControl ItemsSource="{Binding Messages}">
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsUser}" Value="True">
                                <Setter Property="ContentTemplate" Value="{StaticResource UserMessageTemplate}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsUser}" Value="False">
                                <Setter Property="ContentTemplate" Value="{StaticResource AssistantMessageTemplate}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ItemsControl.ItemContainerStyle>
            </ItemsControl>
        </ScrollViewer>

        <!-- Image attachment preview -->
        <Border Grid.Row="2" Padding="8,4"
                Visibility="{Binding HasAttachedImage, Converter={StaticResource BoolToVis}}">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="X" Width="20" Height="20"
                        FontSize="10" Padding="0"
                        Command="{Binding RemoveImageCommand}"
                        VerticalAlignment="Top" />
                <Image Source="{Binding AttachedImageSource}" MaxHeight="60"
                       HorizontalAlignment="Left" Margin="0,0,4,0" />
            </DockPanel>
        </Border>

        <!-- Input area -->
        <Border Grid.Row="3" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0">
                    <!-- Image attach button -->
                    <Button DockPanel.Dock="Left" Content="&#x1F4F7;"
                            Command="{Binding AttachImageCommand}"
                            Width="28" Height="28" FontSize="13" Padding="0" Margin="0,0,4,0"
                            ToolTip="Attach Image"
                            IsEnabled="{Binding IsSending, Converter={StaticResource InverseBool}}" />

                    <!-- Cancel button (visible during generation) -->
                    <Button DockPanel.Dock="Right" Content="&#x25A0;"
                            Command="{Binding CancelGenerationCommand}"
                            Width="28" Height="28" FontSize="12" Padding="0" Margin="4,0,0,0"
                            ToolTip="Stop Generation"
                            Visibility="{Binding IsSending, Converter={StaticResource BoolToVis}}" />

                    <!-- Send button -->
                    <Button DockPanel.Dock="Right" Content="&#x27A4;"
                            Command="{Binding SendMessageCommand}"
                            Width="28" Height="28" FontSize="13" Padding="0" Margin="4,0,0,0"
                            ToolTip="Send (Enter)"
                            IsEnabled="{Binding IsSending, Converter={StaticResource InverseBool}}" />

                    <!-- Input text box -->
                    <TextBox Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                             x:Name="InputTextBox"
                             VerticalAlignment="Center" Padding="6,4"
                             FontSize="12"
                             Background="{DynamicResource BackgroundBrush}"
                             Foreground="{DynamicResource ForegroundBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             MinHeight="28" MaxHeight="80"
                             VerticalScrollBarVisibility="Auto"
                             MaxLength="2000" />
                </DockPanel>

                <!-- Status text -->
                <TextBlock Grid.Row="1" Text="{Binding StatusText}"
                           FontSize="10" Margin="2,4,0,0"
                           Foreground="{DynamicResource ForegroundDimBrush}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
